    "csv_export_warning_body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يحتوي ملف CSV المُصدَّر على بيانات مالية غير مشفرة. تأكد من تخزينه ومشاركته بأمان."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportovaný CSV soubor obsahuje nešifrovaná finanční data. Ujistěte se, že ho bezpečně ukládáte a sdílíte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Den eksporterede CSV-fil indeholder ukrypterede finansielle data. Sørg for at opbevare og dele den sikkert."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die exportierte CSV-Datei enthält unverschlüsselte Finanzdaten. Stelle sicher, dass du sie sicher speicherst und teilst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The exported CSV file contains unencrypted financial data. Make sure to store and share it securely."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El archivo CSV exportado contiene datos financieros sin cifrar. Asegúrate de almacenarlo y compartirlo de forma segura."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le fichier CSV exporté contient des données financières non chiffrées. Veillez à le stocker et à le partager de manière sécurisée."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvezena CSV datoteka sadrži nešifrirane financijske podatke. Pobrinite se da je pohranite i dijelite sigurno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az exportált CSV-fájl titkosítatlan pénzügyi adatokat tartalmaz. Gondoskodjon a biztonságos tárolásáról és megosztásáról."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il file CSV esportato contiene dati finanziari non crittografati. Assicurati di archiviarlo e condividerlo in modo sicuro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "エクスポートされたCSVファイルには暗号化されていない財務データが含まれています。安全に保存・共有してください。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Den eksporterte CSV-filen inneholder ukrypterte finansielle data. Sørg for å lagre og dele den på en sikker måte."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het geëxporteerde CSV-bestand bevat niet-versleutelde financiële gegevens. Zorg ervoor dat je het veilig opslaat en deelt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyeksportowany plik CSV zawiera niezaszyfrowane dane finansowe. Upewnij się, że przechowujesz go i udostępniasz bezpiecznie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O arquivo CSV exportado contém dados financeiros não criptografados. Certifique-se de armazená-lo e compartilhá-lo com segurança."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fișierul CSV exportat conține date financiare necriptate. Asigurați-vă că îl stocați și îl partajați în siguranță."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Экспортированный CSV-файл содержит незашифрованные финансовые данные. Обязательно храните и передавайте его безопасно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Den exporterade CSV-filen innehåller okrypterade finansiella data. Se till att lagra och dela den på ett säkert sätt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dışa aktarılan CSV dosyası şifrelenmemiş finansal veriler içerir. Güvenli bir şekilde saklandığından ve paylaşıldığından emin olun."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导出的CSV文件包含未加密的财务数据。请确保安全存储和分享。"
          }
        }
      }
    },
