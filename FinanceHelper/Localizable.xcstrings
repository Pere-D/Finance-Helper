    "onboarding_feature3_desc": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "خطط للتكاليف الثابتة والدخل وأهداف التوفير — شهريًا أو سنويًا."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Plánujte fixní náklady, příjmy a spořicí cíle — měsíčně nebo ročně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Plan fixed costs, income, and savings goals — monthly or yearly."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Plane Fixkosten, Einnahmen und Sparziele — monatlich oder jährlich."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plan fixed costs, income, and savings goals — monthly or yearly."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Planifica gastos fijos, ingresos y metas de ahorro — mensual o anualmente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planifiez les charges fixes, les revenus et les objectifs d'épargne — mensuellement ou annuellement."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planirajte fiksne troškove, prihode i ciljeve štednje — mjesečno ili godišnje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tervezze meg a fix költségeket, a bevételt és a megtakarítási célokat – havonta vagy évente."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Pianifica costi fissi, entrate e obiettivi di risparmio — mensili o annuali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "固定費、収入、貯蓄目標を月次または年次で計画しましょう。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Planlegg faste kostnader, inntekter og sparemål — månedlig eller årlig."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Plan vaste kosten, inkomsten en spaardoelen — maandelijks of jaarlijks."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Planuj stałe koszty, dochody i cele oszczędnościowe — miesięcznie lub rocznie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Planeje custos fixos, receitas e metas de poupança — mensal ou anualmente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Planificați costuri fixe, venituri și obiective de economii - lunar sau anual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планируйте постоянные расходы, доходы и цели сбережений — ежемесячно или ежегодно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Planera fasta kostnader, inkomster och sparmål — månadsvis eller årsvis."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sabit giderleri, geliri ve tasarruf hedeflerini planlayın — aylık veya yıllık."
          }
