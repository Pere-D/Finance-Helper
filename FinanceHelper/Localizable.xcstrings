    "Ziel gilt erst als erreichbar wenn zusätzlich %lld %@ Ausgaben als Reserve verbleiben.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يُعتبر الهدف قابلاً للتحقيق إلا إذا بقيت نفقات إضافية بنسبة %lld %@ كاحتياطي."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Cíl se považuje za dosažitelný teprve tehdy, pokud navíc zůstane %lld %@ výdajů jako rezerva."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet anses først for at være opnåeligt, når der desuden er %lld %@ udgifter tilbage som reserve."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziel gilt erst als erreichbar wenn zusätzlich %lld %@ Ausgaben als Reserve verbleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The goal is considered achievable only if an additional %lld %@ of the budget remains as a reserve."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El objetivo solo se considerará alcanzable si, además, queda %lld %@ de gastos como reserva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'objectif n'est considéré comme réalisable que si %lld %@ des dépenses restent disponibles à titre de réserve."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cilj se smatra ostvarivim samo ako dodatnih %lld %@ troškova ostane kao rezerva."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A cél csak akkor tekinthető elérhetőnek, ha emellett %lld %@ kiadás marad tartalékként."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'obiettivo è considerato raggiungibile solo se rimane una riserva pari a %lld %@ delle spese."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標は、さらに %lld %@ の支出を予備として残して初めて達成可能とみなされます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet regnes først som oppnåelig når det i tillegg gjenstår %lld %@ utgifter som reserve."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het doel wordt pas als haalbaar beschouwd als er bovendien %lld %@ aan uitgaven als reserve overblijft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel uznaje się za możliwy do osiągnięcia dopiero wtedy, gdy pozostanie dodatkowo %lld %@ wydatków jako rezerwa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A meta só será considerada alcançável se, além disso, %lld %@ das despesas permanecerem como reserva."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Obiectivul este considerat realizabil numai dacă rămân, în plus, %lld %@ din cheltuieli ca rezervă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цель считается достижимой только в том случае, если в качестве резерва останется дополнительно %lld %@ расходов."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet anses inte vara uppnåeligt förrän ytterligare %lld %@ av utgifterna finns kvar som reserv."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hedef, %lld %@ tutarındaki harcamaların yedek olarak kalması durumunda ulaşılabilir sayılır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当额外保留 %lld %@ 的支出作为储备时，该目标才被视为可实现。"
          }
        }
      }
    },
    "Ziel gilt erst als erreichbar wenn zusätzlich %lld Monat%@ Ausgaben als Reserve verbleiben.": {
      "comment": "The text that appears below the \"Reserve\" section in the settings sheet, explaining that the goal is considered reachable as soon as there is enough capital available, regardless of the notgroschenMonths setting.",
      "extractionState": "stale",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يُعتبر الهدف قابلاً للتحقيق إلا إذا بقيت نفقات %lld شهر%@ كاحتياطي."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Cíl se považuje za dosažitelný teprve tehdy, pokud navíc %lld Monat%@ výdajů zůstane jako rezerva."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet anses først for at være opnåeligt, når der desuden er %lld måned%@ udgifter tilbage som reserve."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziel gilt erst als erreichbar wenn zusätzlich %lld Monat%@ Ausgaben als Reserve verbleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Ziel gilt erst als erreichbar wenn zusätzlich %1$lld Monat%2$@ Ausgaben als Reserve verbleiben."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El objetivo solo se considerará alcanzable si, además, queda %lld mes%@ de gastos como reserva."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'objectif n'est considéré comme réalisable que si %lld mois%@ de dépenses restent en réserve."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cilj se smatra ostvarivim samo ako dodatnih %lld mjesec%@ izdataka ostane kao rezerva."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A cél csak akkor tekinthető elérhetőnek, ha a %lld hónap%@ kiadásain felül még tartalék is marad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'obiettivo è considerato raggiungibile solo se rimane una riserva pari a %lld mese%@ delle spese."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標は、%lld ヶ月分%@の支出を予備として残して初めて達成可能とみなされます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet regnes først som oppnåelig når %lld måned%@ av utgiftene gjenstår som reserve."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Het doel wordt pas als haalbaar beschouwd als er bovendien %lld maand%@ aan uitgaven als reserve overblijft."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel uznaje się za możliwy do osiągnięcia dopiero wtedy, gdy pozostanie dodatkowo %lld miesiąc%@ wydatków jako rezerwa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A meta só será considerada alcançável se, além disso, %lld mês%@ das despesas permanecerem como reserva."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Obiectivul este considerat realizabil numai dacă rămân ca rezervă cheltuieli suplimentare de %lld lună%@."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цель считается достижимой только в том случае, если в дополнение к %lld месяц%@ расходам останется резерв."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Målet anses inte vara uppnåeligt förrän ytterligare %lld månad%@ i utgifter finns kvar som reserv."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hedef, %lld ay%@ tutarındaki harcamaların yedek olarak kalması durumunda ulaşılabilir sayılır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "只有当额外保留 %lld 个月%@ 的支出作为储备金时，该目标才被视为可实现。"
          }
        }
      }
    },
