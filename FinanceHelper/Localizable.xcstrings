    "Der Eintrag wird nur in den angegebenen Zeitraum berücksichtigt.": {
      "comment": "A footnote explaining that a budget entry is only considered within its specified timeframe.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتم أخذ هذا الإدخال في الاعتبار إلا خلال الفترة المحددة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Záznam bude zohledněn pouze v uvedeném období."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Oplysningen tages kun i betragtning inden for den angivne periode."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Eintrag wird nur in den angegebenen Zeitraum berücksichtigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The entry will only be considered for the specified time period."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La inscripción solo se tendrá en cuenta durante el periodo indicado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'entrée ne sera prise en compte que pour la période indiquée."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijava će se uzeti u obzir samo za navedeno razdoblje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A bejegyzést csak a megadott időszakra veszik figyelembe."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La voce verrà presa in considerazione solo nel periodo indicato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その登録は、指定された期間内のみ有効となります。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Oppføringen tas kun med i beregningen for den angitte perioden."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De vermelding wordt alleen in de opgegeven periode in aanmerking genomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpis zostanie uwzględniony wyłącznie w podanym okresie."
          }
        },
        "pt-BR": {
