    "Je kürzer der Zeitraum, desto aktueller die Werte.": {
      "comment": "A description below the slider that explains how the values change over time.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كلما كانت الفترة الزمنية أقصر، كانت القيم أكثر حداثة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čím kratší je časové období, tím aktuálnější jsou hodnoty."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Jo kortere tidsperioden er, desto mere aktuelle er tallene."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Je kürzer der Zeitraum, desto aktueller die Werte."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The shorter the time period, the more up-to-date the figures are."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuanto más corto sea el periodo, más actuales serán los datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plus la période est courte, plus les chiffres sont récents."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Što je vremensko razdoblje kraće, to su podaci ažurniji."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minél rövidebb az időszak, annál frissebbek az adatok."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Più breve è il periodo, più aggiornati sono i dati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "期間が短いほど、数値は最新のものになります。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Jo kortere tidsperioden er, desto mer oppdaterte er tallene."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe korter de periode, hoe actueler de cijfers."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Im krótszy okres, tym bardziej aktualne są dane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Quanto menor for o período, mais atuais serão os valores."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cu cât perioada este mai scurtă, cu atât valorile sunt mai actuale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Чем короче период, тем актуальнее показатели."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ju kortare tidsperiod, desto mer aktuella är värdena."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Süre ne kadar kısa olursa, değerler o kadar güncel olur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "时间跨度越短，数据就越及时。"
          }
        }
      }
    },
