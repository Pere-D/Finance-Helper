    "Aus Zinssatz × Restschuld ÷ 12 werden die monatlichen Zinskosten automatisch berechnet.": {
      "comment": "A footer label explaining how mortgage interest is calculated.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم حساب تكاليف الفائدة الشهرية تلقائيًا باستخدام الصيغة: معدل الفائدة × الديون المتبقية ÷ 12."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Měsíční úrokové náklady se automaticky vypočítají podle vzorce: úroková sazba × zbývající dluh ÷ 12."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "De månedlige renteomkostninger beregnes automatisk ud fra formlen: rentesats × restgæld ÷ 12."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aus Zinssatz × Restschuld ÷ 12 werden die monatlichen Zinskosten automatisch berechnet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The monthly interest charges are automatically calculated using the formula: interest rate × remaining balance ÷ 12."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los gastos mensuales por intereses se calculan automáticamente a partir de la fórmula: tipo de interés × deuda pendiente ÷ 12."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les intérêts mensuels sont calculés automatiquement à partir de la formule suivante : taux d'intérêt × solde restant dû ÷ 12."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mjesečni troškovi kamata automatski se izračunavaju prema formuli: kamatna stopa × preostali dug ÷ 12."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A havi kamatköltségeket a kamatláb × fennmaradó tartozás ÷ 12 képlet alapján számítja ki a rendszer automatikusan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli interessi mensili vengono calcolati automaticamente utilizzando la formula: tasso d'interesse × debito residuo ÷ 12."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「金利 × 残債務 ÷ 12」の計算式により、毎月の利息が自動的に算出されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "De månedlige rentekostnadene beregnes automatisk ut fra formelen: rentesats × gjenstående gjeld ÷ 12."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De maandelijkse rentekosten worden automatisch berekend aan de hand van de formule: rentevoet × resterende schuld ÷ 12."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Miesięczne koszty odsetkowe są obliczane automatycznie na podstawie wzoru: stopa procentowa × pozostałe zadłużenie ÷ 12."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os custos mensais com juros são calculados automaticamente a partir da fórmula: taxa de juros × saldo da dívida ÷ 12."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Costurile lunare ale dobânzii se calculează automat pe baza formulei: rata dobânzii × datoria rămasă ÷ 12."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ежемесячные процентные расходы рассчитываются автоматически по формуле: процентная ставка × остаток задолженности ÷ 12."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "De månatliga räntekostnaderna beräknas automatiskt utifrån formeln: räntesats × återstående skuld ÷ 12."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Faiz oranı × kalan borç ÷ 12 formülüyle aylık faiz giderleri otomatik olarak hesaplanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每月利息费用将根据“利率 × 剩余债务 ÷ 12”自动计算得出。"
          }
        }
      }
    },
