    "tip_credit_high": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتجاوز إنفاق بطاقتك الائتمانية 20% من دخلك. حاول أن تجعله أقل من 30٪."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Útrata vaší kreditní kartou přesahuje 20 % příjmů. Zkuste to snížit pod 30 %."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit kreditkortforbrug overstiger 20 % af indkomsten. Prøv at bringe det under 30%."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Kreditkartenausgaben übersteigen 20 % deines Einkommens. Versuche, sie auf unter 30 % zu senken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your credit card spending exceeds 20% of income. Try to bring it below 30%."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El gasto de su tarjeta de crédito supera el 20% de los ingresos. Intente reducirlo por debajo del 30%."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos dépenses par carte de crédit dépassent 20 % de vos revenus. Essayez de le ramener en dessous de 30 %."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Potrošnja vaše kreditne kartice premašuje 20% prihoda. Pokušajte ga smanjiti ispod 30%."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A hitelkártyás kiadása meghaladja a bevétel 20%-át. Próbáld meg 30% alá vinni."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La spesa della tua carta di credito supera il 20% del reddito. Prova a portarlo sotto il 30%."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クレジットカードの支出が収入の 20% を超えています。 30% 以下になるようにしてください。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kredittkortforbruket ditt overstiger 20 % av inntekten. Prøv å få den under 30%."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw creditcarduitgaven bedragen meer dan 20% van uw inkomen. Probeer het onder de 30% te brengen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Your credit card spending exceeds 20% of income. Try to bring it below 30%."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus gastos com cartão de crédito excedem 20% da receita. Tente trazê-lo abaixo de 30%."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cheltuielile cu cardul dvs. de credit depășesc 20% din venit. Încercați să o reduceți sub 30%."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Расходы по вашей кредитной карте превышают 20% дохода. Постарайтесь снизить его до уровня ниже 30%."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina kreditkortsutgifter överstiger 20 % av inkomsten. Försök att få det under 30%."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kredi kartı harcamalarınız gelirinizin %20'sini aşıyor. Yüzde 30'un altına düşürmeye çalışın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的信用卡支出超过收入的 20%。尝试将其降至 30% 以下。"
          }
        }
      }
    },
    "tip_debt_high": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ديونك تتجاوز 40% من إجمالي الأصول. التركيز على سدادها."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš dluh přesahuje 40 % celkových aktiv. Zaměřte se na jeho splácení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din gæld overstiger 40 % af de samlede aktiver. Fokuser på at tilbagebetale det."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schulden übersteigen 40 % deines Gesamtvermögens. Konzentriere dich auf die Rückzahlung."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your debt exceeds 40% of total assets. Focus on repaying it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Su deuda supera el 40% del activo total. Concéntrate en pagarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dette dépasse 40% du total des actifs. Concentrez-vous sur le remboursement."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš dug premašuje 40% ukupne imovine. Usredotočite se na otplatu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tartozása meghaladja a teljes vagyon 40%-át. Koncentrálj a visszafizetésre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo debito supera il 40% del totale attivo. Concentrati sul ripagarlo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの負債は総資産の 40% を超えています。返済することに集中しましょう。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjelden din overstiger 40 % av totale eiendeler. Fokuser på å betale tilbake."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw schuld bedraagt ​​meer dan 40% van het totale vermogen. Concentreer u op het terugbetalen ervan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Your debt exceeds 40% of total assets. Focus on repaying it."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua dívida ultrapassa 40% do ativo total. Concentre-se em reembolsá-lo."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Datoria dvs. depășește 40% din activele totale. Concentrați-vă pe rambursarea acestuia."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш долг превышает 40% от общей суммы активов. Сосредоточьтесь на том, чтобы отплатить за это."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din skuld överstiger 40 % av totala tillgångar. Fokusera på att betala tillbaka det."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Borcunuz toplam aktiflerin %40'ını aşıyor. Geri ödemeye odaklanın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的债务超过总资产的40%。专注于偿还它。"
          }
        }
      }
    },
    "tip_emergency_low": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يغطي صندوق الطوارئ الخاص بك نفقات أقل من شهر واحد. بناء واحدة على وجه السرعة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš pohotovostní fond pokryje výdaje za méně než 1 měsíc. Urychleně jej postavte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din nødkasse dækker mindre end 1 måneds udgifter. Byg en omgående."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Notgroschen deckt weniger als 1 Monat Ausgaben ab. Baue dringend eine Rücklage auf."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your emergency fund covers less than 1 month of expenses. Build one urgently."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu fondo de emergencia cubre menos de 1 mes de gastos. Construya uno urgentemente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre fonds d'urgence couvre moins d'un mois de dépenses. Construisez-en un de toute urgence."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaš hitni fond pokriva manje od 1 mjeseca troškova. Izgradite hitno."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Sürgősségi alapja kevesebb, mint 1 havi kiadásokat fedez. Sürgősen építs egyet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo fondo di emergenza copre meno di 1 mese di spese. Costruiscine uno urgentemente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "緊急基金は 1 か月未満の費用をカバーします。急いで構築してください。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ditt nødfond dekker mindre enn 1 måneds utgifter. Bygg en snarest."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw noodfonds dekt minder dan 1 maand aan uitgaven. Bouw er dringend een."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Your emergency fund covers less than 1 month of expenses. Build one urgently."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu fundo de emergência cobre menos de 1 mês de despesas. Construa um com urgência."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fondul dumneavoastră de urgență acoperă mai puțin de 1 lună de cheltuieli. Construiește unul urgent."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш резервный фонд покрывает расходы менее чем на 1 месяц. Постройте срочно."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din akutfond täcker mindre än 1 månads utgifter. Bygg en snarast."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Acil durum fonunuz 1 aydan az masrafları karşılar. Acilen bir tane inşa edin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的应急基金可支付不到 1 个月的费用。紧急建造一个。"
          }
        }
      }
    },
    "tip_emergency_medium": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اهدف إلى الاحتفاظ بالنفقات لمدة تتراوح من 3 إلى 6 أشهر في حساب جاري أو حساب توفير."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Snažte se držet 3–6 měsíců výdajů na běžném nebo spořicím účtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigt efter at holde 3-6 måneders udgifter på en check- eller opsparingskonto."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziel: mindestens 3–6 Monate Ausgaben in einem Giro- oder Sparkonto halten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Aim to hold 3–6 months of expenses in a checking or savings account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Trate de mantener de 3 a 6 meses de gastos en una cuenta corriente o de ahorros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Essayez de conserver 3 à 6 mois de dépenses sur un compte courant ou un compte d’épargne."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastojte držati 3-6 mjeseci troškova na tekućem ili štednom računu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Törekedjen arra, hogy 3-6 havi kiadásait csekk- vagy megtakarítási számlán tartsa."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerca di conservare 3-6 mesi di spese in un conto corrente o di risparmio."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "3 ～ 6 か月分の支出を当座預金口座または普通預金口座に保管することを目指します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mål å holde 3–6 måneders utgifter på en bruks- eller sparekonto."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Probeer drie tot zes maanden aan uitgaven op een betaal- of spaarrekening te zetten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Aim to hold 3–6 months of expenses in a checking or savings account."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Procure manter de 3 a 6 meses de despesas em uma conta corrente ou poupança."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Urmăriți-vă să păstrați 3-6 luni de cheltuieli într-un cont curent sau de economii."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Старайтесь хранить расходы за 3–6 месяцев на текущем или сберегательном счете."
          }
        },
        "sv": {
          "stringUnit": {
