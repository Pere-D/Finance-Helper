    "Typischer Monatswert aus deinen Transaktionen, Ausreisser werden herausgefiltert.": {
      "comment": "A footer label explaining that the average monthly income is calculated from your transactions, and outliers are filtered out.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "القيمة الشهرية النموذجية المستمدة من معاملاتك، مع استبعاد القيم الشاذة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Typická měsíční hodnota na základě tvých transakcí, výjimečné hodnoty jsou odfiltrovány."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Typisk månedstal baseret på dine transaktioner; afvigende værdier filtreres fra."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Typischer Monatswert aus deinen Transaktionen, Ausreisser werden herausgefiltert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Typical monthly value based on your transactions; outliers are filtered out."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Valor mensual típico basado en tus transacciones; se excluyen los valores atípicos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Valeur mensuelle typique calculée à partir de tes transactions ; les valeurs aberrantes sont exclues."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tipična mjesečna brojka temeljena na vašim transakcijama; izuzeci su filtrirani."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A tranzakcióid alapján számított tipikus havi érték; a szélsőséges értékeket kiszűrjük."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Valore mensile tipico ricavato dalle tue transazioni; i valori anomali vengono filtrati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "取引履歴に基づく典型的な月間値。異常値は除外されています。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Typisk månedlig verdi basert på transaksjonene dine; ekstreme verdier blir filtrert bort."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemiddelde maandelijkse waarde op basis van je transacties; uitschieters worden eruit gefilterd."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Typowa wartość miesięczna na podstawie Twoich transakcji; wartości odstające są odfiltrowywane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Valor mensal típico com base nas suas transações; valores atípicos são filtrados."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Valoarea lunară tipică calculată pe baza tranzacțiilor tale; valorile aberante sunt eliminate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Типичное среднемесячное значение, рассчитанное на основе твоих транзакций; аномальные значения отфильтровываются."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ett typiskt månadsvärde baserat på dina transaktioner; extremvärden filtreras bort."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İşlemlerinden elde edilen tipik aylık değer; olağan dışı değerler filtrelenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "基于你的交易记录得出的典型月度数值，异常值已被过滤掉。"
          }
        }
      }
    },
