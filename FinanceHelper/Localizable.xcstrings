    "day_of_month_footer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تثبيت الأيام التي تلي نهاية الشهر على اليوم الأخير."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dny po konci měsíce se počítají do posledního dne."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dage efter udgangen af ​​en måned er fastspændt til den sidste dag."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tage über Monatsende werden auf den letzten Tag gesetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Days beyond the end of a month are clamped to the last day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los días posteriores al final de un mes se restringen al último día."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les jours au-delà de la fin du mois sont limités au dernier jour."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dani nakon kraja mjeseca vezani su za zadnji dan."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Days beyond the end of a month are clamped to the last day."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I giorni oltre la fine del mese vengono limitati all'ultimo giorno."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Days beyond the end of a month are clamped to the last day."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dager utover slutten av en måned er klemt til siste dag."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dagen na het einde van een maand worden tot de laatste dag beperkt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Days beyond the end of a month are clamped to the last day."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os dias além do final de um mês são limitados ao último dia."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Zilele dincolo de sfârșitul unei luni sunt fixate la ultima zi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дни после конца месяца привязываются к последнему дню."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dagar efter slutet av en månad spänns fast till den sista dagen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ayın sonunu aşan günler son güne sıkıştırılır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
