        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Your data is end-to-end encrypted and synced across all devices signed in to your iCloud account."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Daten werden Ende-zu-Ende verschlüsselt und auf all deinen iCloud-Geräten synchronisiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your data is end-to-end encrypted and synced across all devices signed in to your iCloud account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus datos están cifrados de extremo a extremo y sincronizados en todos los dispositivos con sesión de iCloud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos données sont chiffrées de bout en bout et synchronisées sur tous les appareils connectés à votre compte iCloud."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaši podaci su kriptirani s kraja na kraj i sinkronizirani na svim uređajima prijavljenim na vaš iCloud."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adatai végpontok között titkosítva vannak, és szinkronizálva vannak az iCloud-fiókjába bejelentkezett összes eszközön."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi dati sono crittografati end-to-end e sincronizzati su tutti i dispositivi connessi al tuo account iCloud."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "データはエンドツーエンドで暗号化され、iCloudアカウントにサインインしたすべてのデバイスに同期されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dataene dine er ende-til-ende-kryptert og synkronisert på alle enheter som er logget inn på iCloud-kontoen din."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uw gegevens zijn end-to-end versleuteld en gesynchroniseerd op alle apparaten die zijn aangemeld bij uw iCloud-account."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje dane są szyfrowane end-to-end i synchronizowane na wszystkich urządzeniach zalogowanych do Twojego konta iCloud."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus dados são criptografados de ponta a ponta e sincronizados em todos os dispositivos conectados ao seu iCloud."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Datele dvs. sunt criptate de la capăt la capăt și sincronizate pe toate dispozitivele conectate la contul dvs. iCloud."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши данные зашифрованы по принципу E2E и синхронизируются на всех устройствах, подключённых к вашему iCloud."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina data är end-to-end-krypterade och synkroniserade på alla enheter inloggade på ditt iCloud-konto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Verileriniz uçtan uca şifrelenir ve iCloud hesabınıza giriş yapmış tüm cihazlarınızda eşitlenir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的数据经端对端加密，并在所有登录 iCloud 账户的设备之间同步。"
          }
        }
      }
    },
