        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden profilnak megvannak a saját fiókjai és bejegyzései. Csúsztatással törölheti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ogni profilo ha i propri account e voci. Scorri per eliminare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各プロファイルには独自のアカウントとエントリがあります。スワイプして削除します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hver profil har sine egne kontoer og oppføringer. Sveip for å slette."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Elk profiel heeft zijn eigen accounts en vermeldingen. Veeg om te verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Each profile has its own accounts and entries. Swipe to delete."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada perfil tem suas próprias contas e entradas. Deslize para excluir."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fiecare profil are propriile conturi și intrări. Glisați pentru a șterge."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждый профиль имеет свои учетные записи и записи. Проведите пальцем по экрану, чтобы удалить."
          }
        },
        "sv": {
