    "goals_legend_order_hint": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يبدأ الهدف 2 فقط بعد اكتمال الهدف 1. غيّر الترتيب عبر السحب."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Cíl 2 začne teprve po splnění cíle 1. Změňte pořadí přetažením."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Goal 2 starts only after Goal 1 is reached. Change order via drag or directly in the goal."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziel 2 startet erst nach Abschluss von Ziel 1. Reihenfolge per Drag (↑↓-Taste) oder direkt im Ziel ändern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Goal 2 starts only after Goal 1 is reached. Change order via drag or directly in the goal."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El objetivo 2 comienza sólo después de alcanzar el objetivo 1. Cambia el orden arrastrando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'objectif 2 démarre uniquement après l'accomplissement de l'objectif 1. Modifier l'ordre par glisser-déposer."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cilj 2 počinje tek nakon završetka cilja 1. Promijenite redoslijed povlačenjem."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A 2. cél csak az 1. cél elérése után kezdődik. Módosítsa a sorrendet húzással vagy közvetlenül a célban."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "L'obiettivo 2 inizia solo dopo il completamento dell'obiettivo 1. Cambia l'ordine trascinando."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "目標2は目標1を達成した後に開始します。ドラッグで順序を変更できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Mål 2 starter bare etter at mål 1 er nådd. Endre rekkefølge ved å dra."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Doel 2 start pas na het bereiken van doel 1. Wijzig volgorde via slepen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cel 2 rozpoczyna się dopiero po osiągnięciu celu 1. Zmień kolejność przeciągając."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A meta 2 começa somente após a meta 1 ser concluída. Altere a ordem arrastando."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Obiectivul 2 începe numai după ce obiectivul 1 este atins. Schimbați ordinea prin glisare sau direct în obiectiv."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цель 2 начинается только после достижения цели 1. Измените порядок перетаскиванием."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Mål 2 startar först efter att mål 1 är uppnått. Ändra ordning via drag."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hedef 2, Hedef 1 tamamlandıktan sonra başlar. Sırayı sürükleyerek değiştirin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "目标2仅在目标1完成后开始。通过拖动更改顺序。"
          }
        }
      }
    },
