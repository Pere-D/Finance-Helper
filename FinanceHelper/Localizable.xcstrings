    "onboarding_welcome_subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أموالك — دائماً في الصورة،\nدائماً تحت السيطرة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše finance — vždy přehledně,\nvždy pod kontrolou."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Your finances — always visible,\nalways in control."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Finanzen — immer im Blick,\nimmer unter Kontrolle."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your finances — always visible,\nalways in control."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus finanzas — siempre a la vista,\nsiempre bajo control."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos finances — toujours visibles,\ntoujours sous contrôle."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše financije — uvijek u vidokrugu,\nuvijek pod kontrolom."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Pénzügyei mindig láthatóak,\nmindig kézben tartva."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue finanze — sempre visibili,\nsempre sotto controllo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつでも見える、\nいつでも管理できる家計。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Dine finanser — alltid i sikte,\naltid under kontroll."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jouw financiën — altijd in beeld,\naltijd in controle."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje finanse — zawsze widoczne,\nzawsze pod kontrolą."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas finanças — sempre visíveis,\nsempre sob controle."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Finanțele tale - mereu vizibile,\nmereu în control."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши финансы — всегда на виду,\nвсегда под контролем."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina finanser — alltid synliga,\naltid under kontroll."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Finanslarınız — her zaman görünür,\nher zaman kontrol altında."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您的财务 — 随时掌握，\n随时掌控。"
          }
        }
      }
    },
