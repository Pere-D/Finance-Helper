    "budget_leave_to_analyse_fmt": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ستغادر هذه الشاشة وتفتح شاشة التحليل باستخدام عامل التصفية «%@». وبذلك ستتمكن من معرفة المعاملات التي تم احتسابها بالضبط."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Opustíš tento pohled a otevřeš analytický pohled s filtrem „%@“. Tak uvidíš přesně, které transakce byly započítány."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du forlader denne visning og åbner analysevisningen med filteret «%@». Så kan du se præcis, hvilke transaktioner der er blevet talt med."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du verlässt diese Ansicht und öffnest die Analyseansicht mit dem Filter «%@». So siehst du genau welche Transaktionen gezählt wurden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll exit this view and open the analysis view using the \"%@\" filter. This will show you exactly which transactions were counted."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sal de esta vista y abre la vista de análisis con el filtro «%@». Así podrás ver exactamente qué transacciones se han contabilizado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu quittes cet écran et tu ouvres l'écran d'analyse avec le filtre « %@ ». Tu peux ainsi voir exactement quelles transactions ont été comptabilisées."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Napustit ćete ovaj prikaz i otvoriti prikaz analize koristeći filtar '%@'. Time ćete točno vidjeti koje su transakcije bile prebrojane."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Elhagyod ezt a nézetet, és megnyitod az „%@” szűrővel ellátott elemzési nézetet. Így pontosan láthatod, mely tranzakciókat számolták össze."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esci da questa schermata e apri la schermata di analisi con il filtro «%@». In questo modo potrai vedere esattamente quali transazioni sono state conteggiate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画面を閉じて、「%@」というフィルターが適用された分析画面を開きます。そうすれば、どの取引が集計されたかが正確に確認できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du forlater denne visningen og åpner analysevisningen med filteret «%@». Slik ser du nøyaktig hvilke transaksjoner som er telt med."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je verlaat dit scherm en opent het analyseoverzicht met het filter «%@». Zo kun je precies zien welke transacties zijn meegeteld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Opuszczasz ten widok i otwierasz widok analizy z filtrem „%@”. W ten sposób możesz dokładnie sprawdzić, które transakcje zostały uwzględnione."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você sai desta tela e abre a tela de análise com o filtro «%@». Assim, você pode ver exatamente quais transações foram contabilizadas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ieși din această vizualizare și deschizi vizualizarea de analiză cu filtrul „%@”. Astfel, poți vedea exact ce tranzacții au fost luate în calcul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы выходите из этого окна и открываете окно анализа с фильтром «%@». Так вы сможете точно увидеть, какие транзакции были учтены."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du lämnar den här vyn och öppnar analysvyn med filtret ”%@”. På så sätt kan du se exakt vilka transaktioner som har räknats."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu ekrandan çıkıp «%@» filtresiyle analiz ekranını açarsın. Böylece hangi işlemlerin sayıldığını tam olarak görebilirsin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你将退出当前视图，并使用过滤器“%@”打开分析视图。这样你就能清楚地看到哪些交易被计入了统计。"
          }
        }
      }
    },
