          "stringUnit": {
            "state": "translated",
            "value": "Gastos mensuales de tarjeta de crédito en relación con los ingresos. Objetivo: menos del 30%."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dépenses mensuelles de carte de crédit par rapport au revenu. Objectif : inférieur à 30 %."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mjesečni troškovi kreditne kartice u odnosu na prihod. Cilj: ispod 30%."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Monthly credit card expenses relative to income. Target: below 30%."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spese mensili sulla carta di credito in relazione al reddito. Obiettivo: inferiore al 30%."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "収入に対する毎月のクレジットカード費用。目標：30%未満。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
