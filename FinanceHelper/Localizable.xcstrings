    "goals_empty_subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر فئة وأدخل مبلغك المستهدف. سنحسب متى يمكنك تحمّله."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte kategorii a zadejte cílovou částku. Vypočítáme, kdy si to budete moci dovolit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Choose a category and enter your target amount. We'll calculate when you can afford it."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Kategorie und gib deinen Zielbetrag ein. Wir berechnen, wann du es dir leisten kannst."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose a category and enter your target amount. We'll calculate when you can afford it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una categoría e introduce tu importe objetivo. Calcularemos cuándo podrás permitírtelo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une catégorie et entrez votre montant cible. Nous calculerons quand vous pourrez vous l'offrir."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite kategoriju i unesite ciljni iznos. Izračunat ćemo kada si to možete priuštiti."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válasszon egy kategóriát, és adja meg a célösszeget. Kiszámoljuk, mikor engedheti meg magának."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli una categoria e inserisci il tuo importo obiettivo. Calcoleremo quando potrai permettertelo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カテゴリを選んで目標額を入力してください。いつ達成できるか計算します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg en kategori og skriv inn målbeløpet. Vi beregner når du har råd til det."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een categorie en voer je doelbedrag in. We berekenen wanneer je het je kunt veroorloven."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz kategorię i wprowadź kwotę docelową. Obliczymy, kiedy będziesz mógł sobie na to pozwolić."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma categoria e insira o valor alvo. Calcularemos quando você poderá arcar com isso."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți o categorie și introduceți suma țintă. Vom calcula când îți poți permite."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите категорию и введите целевую сумму. Мы рассчитаем, когда вы сможете это себе позволить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj en kategori och ange ditt målbelopp. Vi beräknar när du kan ha råd med det."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir kategori seçin ve hedef tutarınızı girin. Bunu ne zaman karşılayabileceğinizi hesaplayacağız."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个类别并输入目标金额。我们将计算您何时能实现。"
          }
        }
      }
    },
