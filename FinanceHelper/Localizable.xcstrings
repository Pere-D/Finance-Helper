    "onboarding_feature2_desc": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افهم كم من المال يدخل ويخرج كل شهر، مقسّم حسب المصدر."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Pochopte, kolik peněz každý měsíc přichází a odchází, rozdělených podle zdroje."
          }
        },
