    "Kein Puffer — Ziel gilt als erreichbar sobald genug Kapital vorhanden ist.": {
      "comment": "A description of the \"No buffer\" option in the goals settings sheet.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يوجد احتياطي — يُعتبر الهدف قابلاً للتحقيق بمجرد توفر رأس المال الكافي."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádná rezerva — cíl se považuje za dosažitelný, jakmile je k dispozici dostatek kapitálu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen buffer — målet anses for opnåeligt, så snart der er tilstrækkelig kapital til rådighed."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Puffer — Ziel gilt als erreichbar sobald genug Kapital vorhanden ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No buffer — The goal is considered achievable as soon as enough capital is available."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin margen: el objetivo se considera alcanzable en cuanto se disponga de capital suficiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pas de marge de sécurité — l'objectif est considéré comme réalisable dès qu'il y a suffisamment de capital disponible."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez međuspremnika — cilj se smatra ostvarivim čim je dostupan dovoljan kapital."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs tartalék — a cél akkor tekinthető elérhetőnek, amint elegendő tőke áll rendelkezésre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun margine: l'obiettivo è considerato raggiungibile non appena è disponibile capitale sufficiente."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "バッファなし — 十分な資本が確保され次第、目標は達成可能とみなされる。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen buffer — Målet regnes som oppnåelig så snart det foreligger tilstrekkelig kapital."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen buffer — Het doel wordt als haalbaar beschouwd zodra er voldoende kapitaal beschikbaar is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Brak rezerwy — cel uznaje się za osiągalny, gdy tylko zgromadzony zostanie wystarczający kapitał."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem reserva — a meta é considerada alcançável assim que houver capital suficiente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fără rezervă — obiectivul este considerat realizabil de îndată ce se dispune de capital suficient."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без резерва — цель считается достижимой, как только будет собрано достаточное количество капитала."
          }
        },
