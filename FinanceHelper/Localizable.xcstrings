    "account_income_entry_hint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بعد الحفظ، يمكنك إضافة الدخل والمصاريف الشهرية من خلال تفاصيل الحساب."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Po uložení můžeš přidat příjmy a výdaje přímo v detailech účtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Når du har gemt, skal du åbne kontoen for at tilføje månedlige indtægter, udgifter og besparelser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gehalt, Miete und weitere Einträge kannst du nach dem Speichern direkt in den Konto-Details hinzufügen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After saving, open the account to add monthly income, expenses and savings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tras guardar, abre la cuenta para agregar ingresos, gastos y ahorros mensuales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Après l'enregistrement, ouvre le compte pour ajouter revenus, dépenses et épargne mensuels."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nakon spremanja, otvori račun za dodavanje mjesečnih prihoda, troškova i štednje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "After saving, open the account to add monthly income, expenses and savings."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dopo il salvataggio, apri il conto per aggiungere entrate, spese e risparmi mensili."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保存後にアカウントを開くと、月収・支出・貯蓄を追加できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Etter lagring, åpne kontoen for å legge til månedlige inntekter, utgifter og sparing."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik na het opslaan op de rekening om maandelijkse inkomsten, uitgaven en besparingen toe te voegen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Po zapisaniu otwórz konto, aby dodać miesięczne dochody, wydatki i oszczędności."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Após economizar, abra a conta para somar receitas, despesas e poupanças mensais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "După economisire, deschideți contul pentru a adăuga venituri lunare, cheltuieli și economii."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "После сохранения откройте счёт, чтобы добавить ежемесячные доходы, расходы и сбережения."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Öppna kontot efter sparning för att lägga till månadsinkomster, utgifter och sparande."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaydettikten sonra aylık gelir, gider ve tasarruf eklemek için hesabı aç."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "储蓄后，开设账户以添加每月收入、支出和储蓄。"
          }
        }
      }
    },
