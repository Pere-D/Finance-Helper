    "budget_avg_months_hint": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "المتوسط على مدى %lld أشهر. هل هناك ميزانية مفقودة؟ اضغط على «إنشاء» لإنشاء إدخال ميزانية مباشرةً."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Průměr za %lld měsíců. Chybí rozpočet? Klikni na „Vytvořit“ a ihned vytvoř záznam v rozpočtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gennemsnit baseret på %lld måneder. Mangler der et budget? Tryk på »Opret« for straks at oprette en budgetpost."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durchschnitt aus %lld Monaten. Fehlt ein Budget? Tippe «Anlegen» um direkt einen Budgeteintrag zu erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Average over %lld months. Is a budget missing? Tap “Create” to add a budget entry right away."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Media de %lld meses. ¿Falta algún presupuesto? Pulsa «Crear» para crear directamente una entrada de presupuesto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Moyenne sur %lld mois. Il manque un budget ? Cliquez sur « Créer » pour créer directement une entrée de budget."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prosjek preko %lld mjeseci. Nedostaje li proračun? Dodirnite 'Stvori' kako biste odmah stvorili unos proračuna."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld hónap átlaga. Hiányzik egy költségvetés? Kattints az „Új” gombra, hogy azonnal létrehozz egy költségvetési tételt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Media di %lld mesi. Manca un budget? Tocca «Crea» per inserire direttamente una voce di budget."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lldヶ月の平均値です。予算が不足していますか？「作成」をタップして、すぐに予算項目を作成してください。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjennomsnitt av %lld måneder. Mangler det et budsjett? Trykk på «Opprett» for å opprette en budsjettpost med en gang."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gemiddelde over %lld maanden. Ontbreekt er een budget? Tik op ‘Aanmaken’ om direct een budgetpost aan te maken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Średnia z %lld miesięcy. Brakuje pozycji budżetowej? Wpisz „Utwórz”, aby od razu utworzyć pozycję budżetową."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Média de %lld meses. Falta algum orçamento? Digite “Criar” para criar diretamente um registro de orçamento."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Media pe %lld luni. Lipsește un buget? Apasă pe „Creează” pentru a crea direct o înregistrare de buget."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Среднее значение за %lld месяцев. Отсутствует запись о бюджете? Нажмите «Создать», чтобы сразу создать запись о бюджете."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Genomsnitt över %lld månader. Saknas en budget? Tryck på ”Skapa” för att direkt lägga till en budgetpost."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld ayın ortalaması. Bütçe eksik mi? «Oluştur» seçeneğine dokunarak doğrudan bir bütçe girişi oluşturabilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld个月的平均值。缺少预算项目吗？点击“创建”即可直接添加预算条目。"
          }
        }
      }
    },
