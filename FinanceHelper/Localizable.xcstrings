    "Gute Regeln werden in zukünftige App-Versionen aufgenommen — danke für deinen Beitrag!": {
      "comment": "A footer label explaining that good rules will be included in future app versions, and thanking the user for contributing.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم تضمين القواعد الجيدة في الإصدارات المستقبلية من التطبيق — شكرًا على مساهمتك!"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobrá pravidla budou zahrnuta do budoucích verzí aplikace — děkujeme za tvůj příspěvek!"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Gode regler vil blive indarbejdet i fremtidige app-versioner — tak for dit bidrag!"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gute Regeln werden in zukünftige App-Versionen aufgenommen — danke für deinen Beitrag!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Good rules will be included in future versions of the app—thanks for your contribution!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las buenas reglas se incluirán en futuras versiones de la aplicación. ¡Gracias por tu aportación!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les bonnes règles seront intégrées dans les prochaines versions de l'application — merci pour ta contribution !"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre pravila bit će uključena u buduće verzije aplikacije — hvala na vašem doprinosu!"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A jó szabályokat beépítjük a jövőbeli alkalmazásverziókba — köszönjük a hozzájárulásodat!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le regole valide verranno inserite nelle future versioni dell'app — grazie per il tuo contributo!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "優れたルールは今後のアプリのバージョンに反映されます。ご投稿ありがとうございます！"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gode regler vil bli inkludert i fremtidige versjoner av appen — takk for bidraget ditt!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Goede regels worden opgenomen in toekomstige versies van de app — bedankt voor je bijdrage!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dobre zasady zostaną uwzględnione w przyszłych wersjach aplikacji — dziękujemy za Twój wkład!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As boas regras serão incorporadas nas futuras versões do aplicativo — obrigado pela sua contribuição!"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Regulile bune vor fi incluse în versiunile viitoare ale aplicației — îți mulțumim pentru contribuție!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хорошие правила будут включены в будущие версии приложения — спасибо за твой вклад!"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Bra regler kommer att införas i framtida versioner av appen — tack för ditt bidrag!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
