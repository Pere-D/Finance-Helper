    "tip_investment_low": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكنك توفير أو استثمار أقل من 10% من دخلك. قم بإعداد إدخالات الادخار أو الاستثمار في مخطط الميزانية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Spoříte nebo investujete méně než 10 % svých příjmů. Nastavte položky spoření nebo investic v plánovači rozpočtu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sparer eller investerer mindre end 10 % af din indkomst. Opsæt besparelser eller investeringsposter i budgetplanlæggeren."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sparst oder investierst weniger als 10 % deines Einkommens. Richte Spar- oder ETF-Sparpläne im Budgetplaner ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You save or invest less than 10% of your income. Set up savings or investment entries in the budget planner."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ahorras o inviertes menos del 10% de tus ingresos. Configure entradas de ahorros o inversiones en el planificador de presupuesto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous épargnez ou investissez moins de 10 % de vos revenus. Configurez des entrées d’épargne ou d’investissement dans le planificateur budgétaire."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Štedite ili ulažete manje od 10% svog prihoda. Postavite unose štednje ili ulaganja u planer proračuna."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jövedelmének kevesebb mint 10%-át takarítja meg vagy fekteti be. Állítson be megtakarítási vagy befektetési bejegyzéseket a költségvetés-tervezőben."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Risparmi o investi meno del 10% del tuo reddito. Imposta voci di risparmio o di investimento nel pianificatore di budget."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "貯蓄や投資に充てているのは収入の 10% 未満です。予算プランナーで貯蓄または投資のエントリを設定します。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sparer eller investerer mindre enn 10 % av inntekten din. Sett opp spare- eller investeringsoppføringer i budsjettplanleggeren."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U spaart of belegt minder dan 10% van uw inkomen. Spaar- of beleggingsboekingen instellen in de budgetplanner."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "You save or invest less than 10% of your income. Set up savings or investment entries in the budget planner."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você economiza ou investe menos de 10% de sua renda. Configure entradas de poupança ou investimento no planejador de orçamento."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Economisiți sau investiți mai puțin de 10% din venit. Configurați economii sau intrări de investiții în planificatorul bugetar."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы откладываете или инвестируете менее 10% своего дохода. Настройте записи сбережений или инвестиций в планировщике бюджета."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sparar eller investerar mindre än 10 % av din inkomst. Ställ in sparande eller investeringsposter i budgetplaneraren."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelirinizin %10'undan daha azını biriktirir veya yatırım yaparsınız. Bütçe planlayıcıda tasarruf veya yatırım girişlerini ayarlayın."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您储蓄或投资的金额低于收入的 10%。在预算规划器中设置储蓄或投资条目。"
          }
        }
      }
    },
