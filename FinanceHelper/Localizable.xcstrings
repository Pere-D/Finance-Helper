    "Deine geplanten Ausgaben (%@) sind höher als dein Einkommen.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نفقاتك المتوقعة (%@) أعلى من دخلك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tvé plánované výdaje (%@) jsou vyšší než tvé příjmy."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dine planlagte udgifter (%@) er højere end din indkomst."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine geplanten Ausgaben (%@) sind höher als dein Einkommen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your planned expenses (%@) are higher than your income."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus gastos previstos (%@) son superiores a tus ingresos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tes dépenses prévues (%@) sont supérieures à tes revenus."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaši planirani troškovi (%@) veći su od vaših prihoda."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A tervezett kiadásaid (%@) magasabbak, mint a bevételed."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue spese previste (%@) sono superiori al tuo reddito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予定している支出（%@）は、収入を上回っています。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "De planlagte utgiftene dine (%@) er høyere enn inntekten din."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je geplande uitgaven (%@) zijn hoger dan je inkomen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje planowane wydatki (%@) są wyższe niż Twoje dochody."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Suas despesas planejadas (%@) são maiores do que sua renda."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cheltuielile pe care le-ai planificat (%@) sunt mai mari decât veniturile tale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Твои запланированные расходы (%@) превышают твой доход."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina planerade utgifter (%@) är högre än din inkomst."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Planladığın harcamalar (%@), gelirinden daha yüksek."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的计划支出（%@）高于你的收入。"
          }
        }
      }
    },
    "Deine Schuldenrückzahlungen machen über 30% deines Einkommens aus. Das kann die finanzielle Flexibilität einschränken.": {
      "comment": "Tooltip text in the Sankey diagram indicating that a high debt-to-income ratio could restrict financial flexibility.",
      "isCommentAutoGenerated": true
    },
    "Deine Schuldenrückzahlungen machen über 30% des Einkommens aus. Das kann die finanzielle Flexibilität einschränken.": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تشكل مدفوعات سداد ديونك أكثر من 30% من دخلك. وقد يؤدي ذلك إلى تقييد مرونتك المالية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Splátky tvých dluhů tvoří více než 30 % tvého příjmu. To může omezit tvou finanční flexibilitu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dine gældsafdrag udgør over 30 % af din indkomst. Det kan begrænse din økonomiske fleksibilitet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Schuldenrückzahlungen machen über 30% des Einkommens aus. Das kann die finanzielle Flexibilität einschränken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your debt payments account for more than 30% of your income. This can limit your financial flexibility."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El pago de tus deudas supone más del 30 % de tus ingresos. Esto puede limitar tu flexibilidad financiera."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le remboursement de tes dettes représente plus de 30 % de tes revenus. Cela peut limiter ta marge de manœuvre financière."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše otplate duga čine više od 30% vaših prihoda. To može ograničiti vašu financijsku fleksibilnost."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az adósságtörlesztéseid a jövedelmed több mint 30%-át teszik ki. Ez korlátozhatja a pénzügyi rugalmasságodat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il rimborso dei tuoi debiti rappresenta oltre il 30% del tuo reddito. Ciò può limitare la tua flessibilità finanziaria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "借金の返済額が収入の30％以上を占めています。これにより、経済的な余裕が制限される可能性があります。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjeldsnedbetalingen din utgjør over 30 % av inntekten din. Dette kan begrense din økonomiske fleksibilitet."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je aflossingen maken meer dan 30% van je inkomen uit. Dat kan je financiële flexibiliteit beperken."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Spłaty Twoich długów stanowią ponad 30% Twoich dochodów. Może to ograniczyć Twoją elastyczność finansową."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O pagamento das suas dívidas representa mais de 30% da sua renda. Isso pode limitar sua flexibilidade financeira."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Rambursările datoriilor tale reprezintă peste 30% din venituri. Acest lucru îți poate limita flexibilitatea financiară."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выплаты по долгам составляют более 30 % твоего дохода. Это может ограничить твою финансовую гибкость."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina skuldåterbetalningar utgör över 30 % av din inkomst. Det kan begränsa din ekonomiska flexibilitet."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Borç geri ödemelerin gelirinin %30’undan fazlasını oluşturuyor. Bu durum mali esnekliğini kısıtlayabilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的债务偿还额占收入的30%以上。这可能会限制你的财务灵活性。"
          }
        }
      }
    },
