          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik op + om een eigen trefwoord\naan een categorie te koppelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Naciśnij przycisk +, aby powiązać własny hasło\nz kategorią."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em + para associar uma palavra-chave\na uma categoria."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atinge butonul + pentru a asocia un cuvânt-cheie propriu\ncu o categorie."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
