    "profile_footer": {
      "comment": "Jedes Profil hat eigene Konten und Buchungen. Wische zum Löschen.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "كل ملف تعريف له حساباته وإدخالاته الخاصة. اسحب للحذف."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Each profile has its own accounts and entries. Swipe to delete."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Each profile has its own accounts and entries. Swipe to delete."
          }
        },
