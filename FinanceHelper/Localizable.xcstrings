    "onboarding_currency_disclaimer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أسعار الصرف تقديرية بدون رسوم. تبقى جميع المبالغ مخزّنة بعملتها الأصلية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Směnné kurzy jsou odhady bez poplatků. Všechny částky zůstávají uloženy v původní měně."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Exchange rates are estimates without fees. All amounts remain stored in their original currency."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wechselkurse sind Schätzungen ohne Gebühren. Alle Beträge bleiben in der Originalwährung gespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exchange rates are estimates without fees. All amounts remain stored in their original currency."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las tasas de cambio son estimaciones sin comisiones. Todos los importes permanecen en su moneda original."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les taux de change sont des estimations sans frais. Tous les montants restent dans leur devise d'origine."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tečajevi su procjene bez naknada. Svi iznosi ostaju pohranjeni u originalnoj valuti."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az árfolyamok díjak nélküli becslések. Minden összeg az eredeti pénznemében marad."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tassi di cambio sono stime senza commissioni. Tutti gli importi rimangono nella valuta originale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "為替レートは手数料なしの概算値です。すべての金額は元の通貨で保存されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Valutakurser er estimater uten gebyrer. Alle beløp lagres i originalvalutaen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wisselkoersen zijn schattingen zonder kosten. Alle bedragen worden in de oorspronkelijke valuta opgeslagen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kursy wymiany są szacunkami bez opłat. Wszystkie kwoty są przechowywane w oryginalnej walucie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As taxas de câmbio são estimativas sem taxas. Todos os valores permanecem armazenados na moeda original."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ratele de schimb sunt estimative fără comisioane. Toate sumele rămân stocate în moneda lor originală."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обменные курсы являются приблизительными без учёта комиссий. Все суммы хранятся в исходной валюте."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Växelkurser är uppskattningar utan avgifter. Alla belopp lagras i ursprungsvalutan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Döviz kurları, ücret içermeyen tahminlerdir. Tüm tutarlar orijinal para biriminde saklanır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "汇率为估算值，不含手续费。所有金额以原始货币存储。"
          }
        }
      }
    },
    "onboarding_currency_subtitle": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختر عملتك الرئيسية. سيتم تحويل المبالغ بعملات أخرى بالأسعار الحالية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte svou hlavní měnu. Částky v jiných měnách jsou převedeny pomocí aktuálních kurzů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Choose your main currency. Amounts in other currencies are converted using current rates."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle deine Hauptwährung. Beträge anderer Währungen werden anhand aktueller Kurse umgerechnet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose your main currency. Amounts in other currencies are converted using current rates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige tu moneda principal. Los importes en otras monedas se convierten usando los tipos actuales."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez votre devise principale. Les montants dans d'autres devises seront convertis avec les taux actuels."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite svoju glavnu valutu. Iznosi u drugim valutama se pretvaraju prema trenutnim tečajevima."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassza ki a fő pénznemet. A többi pénznemben lévő összegek átváltása az aktuális árfolyamon történik."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli la tua valuta principale. Gli importi in altre valute vengono convertiti con i tassi attuali."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メイン通貨を選択してください。他の通貨の金額は現在のレートで換算されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg din hovedvaluta. Beløp i andre valutaer konverteres med gjeldende kurser."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies je hoofdvaluta. Bedragen in andere valuta worden omgerekend met actuele koersen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz główną walutę. Kwoty w innych walutach są przeliczane według bieżących kursów."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha sua moeda principal. Os valores em outras moedas são convertidos com as taxas atuais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alegeți moneda dvs. principală. Sumele în alte valute sunt convertite folosind ratele curente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите основную валюту. Суммы в других валютах конвертируются по текущему курсу."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj din huvudvaluta. Belopp i andra valutor omräknas med aktuella kurser."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana para biriminizi seçin. Diğer para birimlerindeki tutarlar güncel kurlar kullanılarak dönüştürülür."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择主要货币。其他货币的金额将按当前汇率换算。"
          }
        }
      }
    },
