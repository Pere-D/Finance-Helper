    "Tippe auf + um ein eigenes Stichwort\nmit einer Kategorie zu verknüpfen.": {
      "comment": "A description below the button to add a custom rule, explaining its purpose.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على + لربط كلمة مفتاحية خاصة بك\nبإحدى الفئات."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Klikni na + a přiřaď vlastní klíčové slovo\nk určité kategorii."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk på + for at knytte et eget nøgleord\ntil en kategori."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf + um ein eigenes Stichwort\nmit einer Kategorie zu verknüpfen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap + to link a custom keyword\nto a category."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa en el signo + para vincular una palabra clave propia\na una categoría."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuie sur + pour associer un mot-clé de ton choix\nà une catégorie."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite + da povežete vlastitu ključnu riječ s kategorijom."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Érintse meg a + gombot, hogy egy saját kulcsszót\negy kategóriához rendeljen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca il segno + per associare una parola chiave personalizzata\na una categoria."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「+」をタップして、独自のキーワードを\nカテゴリに関連付けます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
