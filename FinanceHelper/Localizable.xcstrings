    "Noch keine Budgetplanung vorhanden — übernimm einzelne Vorschläge oder alle.": {
      "comment": "A message displayed when a user has no budget plan yet, offering to either take individual suggestions or apply all of them.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا توجد خطة ميزانية حتى الآن — يمكنك اعتماد اقتراحات فردية أو جميعها."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatím není k dispozici žádný rozpočet — převezmi jednotlivé návrhy nebo všechny."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der foreligger endnu ingen budgetplanlægning — du kan vælge at overtage enkelte forslag eller dem alle."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Noch keine Budgetplanung vorhanden — übernimm einzelne Vorschläge oder alle."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No budget plan yet — adopt individual suggestions or all of them."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay un plan presupuestario: puedes aceptar algunas propuestas o todas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune planification budgétaire n'est encore disponible — reprends certaines propositions ou toutes."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Još nema plana proračuna — usvojiti pojedinačne prijedloge ili sve njih."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Még nincs költségvetési terv — vedd át az egyes javaslatokat vagy az összeset."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non è ancora stata elaborata una pianificazione di bilancio — puoi adottare singole proposte o tutte."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ予算計画は作成されていません — 個別の提案を採用するか、すべてを採用してください。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det foreligger ennå ingen budsjettplanlegging — ta med enkelte forslag eller alle."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is nog geen begrotingsplanning beschikbaar — neem afzonderlijke voorstellen of alle voorstellen over."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie ma jeszcze planu budżetowego — możesz przyjąć poszczególne propozycje lub wszystkie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ainda não há um planejamento orçamentário — adote sugestões individuais ou todas elas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Nu există încă o planificare bugetară — preia propunerile individuale sau pe toate."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
