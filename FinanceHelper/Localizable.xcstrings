    "Importiere deinen ersten Bankauszug, um\ndeine Ausgaben zu analysieren.": {
      "comment": "A description below the button that allows users to import their bank statements, explaining the purpose of the feature.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استورد كشف حسابك المصرفي الأول من أجل\nتحليل نفقاتك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Načti svůj první výpis z účtu, abys\nmohl analyzovat své výdaje."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer dit første kontoudtog for at\nanalysere dine udgifter."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Importiere deinen ersten Bankauszug, um\ndeine Ausgaben zu analysieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import your first bank statement to\nanalyze your expenses."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa tu primer extracto bancario para\nanalizar tus gastos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe ton premier relevé bancaire pour\nanalyser tes dépenses."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uvezi svoj prvi bankovni izvod i analiziraj svoje troškove."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Töltsd be az első bankszámlakivonatodat, hogy\nelemzd a kiadásaidat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa il tuo primo estratto conto bancario per\nanalizzare le tue spese."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初の銀行取引明細をインポートして、\n支出を分析しましょう。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Importer din første kontoutskrift for å\nanalysere utgiftene dine."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importeer je eerste bankafschrift om\nje uitgaven te analyseren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaimportuj swój pierwszy wyciąg bankowy, aby\nprzeanalizować swoje wydatki."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe seu primeiro extrato bancário para\nanalisar suas despesas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Importă primul tău extras de cont pentru a\nîți analiza cheltuielile."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортируйте свою первую выписку из банка, чтобы\nпроанализировать свои расходы."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Importera ditt första kontoutdrag för att\nanalysera dina utgifter."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Harcamalarını analiz etmek için\nilk banka hesap özetini içe aktar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入你的第一份银行对账单，以便\n分析你的开支。"
          }
        }
      }
    },
