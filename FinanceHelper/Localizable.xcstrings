    "language_footer": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "في إعدادات iOS → مساعد الشؤون المالية → اللغة، يمكنك اختيار اللغة الإنجليزية أو الألمانية أو الفرنسية أو الإسبانية أو الكرواتية أو التشيكية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V iOS Settings → Finance Helper → Language si můžete vybrat angličtinu, němčinu, francouzštinu, španělštinu, chorvatštinu nebo češtinu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "I iOS-indstillinger → Økonomihjælp → Sprog kan du vælge engelsk, tysk, fransk, spansk, kroatisk eller tjekkisk."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unter iOS-Einstellungen → Finance Helper → Sprache kannst du Englisch, Deutsch, Französisch, Spanisch, Kroatisch oder Tschechisch wählen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "In iOS Settings → Finance Helper → Language you can choose English, German, French, Spanish, Croatian, or Czech."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "En Configuración de iOS → Ayudante de finanzas → Idioma, puede elegir inglés, alemán, francés, español, croata o checo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "In iOS Settings → Finance Helper → Language you can choose English, German, French, Spanish, Croatian, or Czech."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "U iOS Settings → Finance Helper → Language možete odabrati engleski, njemački, francuski, španjolski, hrvatski ili češki."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az iOS Beállítások → Pénzügyi segítő → Nyelv menüpontjában választhat angol, német, francia, spanyol, horvát vagy cseh nyelvet."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nelle Impostazioni iOS → Aiuto finanziario → Lingua puoi scegliere inglese, tedesco, francese, spagnolo, croato o ceco."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "iOS 設定 → Finance Helper → Language で、英語、ドイツ語、フランス語、スペイン語、クロアチア語、またはチェコ語を選択できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "I iOS-innstillinger → Økonomihjelp → Språk kan du velge engelsk, tysk, fransk, spansk, kroatisk eller tsjekkisk."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "In iOS-instellingen → Financiële Helper → Taal kunt u Engels, Duits, Frans, Spaans, Kroatisch of Tsjechisch kiezen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
