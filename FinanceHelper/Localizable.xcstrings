    "Keine vergleichbaren Daten gefunden.\nImportiere Transaktionen in der Analyse-Ansicht.": {
      "comment": "A message displayed when there are no comparable transaction data to display in the Sankey chart. It instructs the user to import transactions in the \"Analyse\" view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
