    "Empfehlung: mindestens 10–20%% des Einkommens sparen oder investieren. Aktuell: %lld%%.": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "التوصية: ادخر أو استثمر ما لا يقل عن 10–20%% من الدخل. حالياً: %lld%%."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Doporučení: spořit nebo investovat alespoň 10–20 % příjmu. Aktuálně: %lld%%."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Anbefaling: Spar eller invester mindst 10–20 % af indkomsten. Aktuelt: %lld%%."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Empfehlung: mindestens 10–20%% des Einkommens sparen oder investieren. Aktuell: %lld%%."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recommendation: Save or invest at least 10–20% of your income. Current: %lld%%."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendación: ahorrar o invertir al menos entre el 10 % y el 20 % de los ingresos. Actualmente: %lld%%."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Recommandation : épargner ou investir au moins 10 à 20 % de ses revenus. Actuellement : %lld%%."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Preporuka: štedite ili ulagajte najmanje 10–20% svojih prihoda. Trenutna brojka: %lld%%."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajánlás: a jövedelem legalább 10–20%-át tegyük félre vagy fektessük be. Jelenleg: %lld%%."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Raccomandazione: risparmiare o investire almeno il 10–20%% del reddito. Attualmente: %lld%%."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "推奨：収入の少なくとも10～20％を貯蓄または投資に回すこと。現在の状況：%lld%％。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Anbefaling: Spar eller invester minst 10–20 % av inntekten. For øyeblikket: %lld%%."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aanbeveling: spaar of beleg ten minste 10–20%% van je inkomen. Huidige stand: %lld%%."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zalecenie: oszczędzać lub inwestować co najmniej 10–20%% dochodów. Obecnie: %lld%%."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomendação: economizar ou investir pelo menos 10–20%% da renda. Atualmente: %lld%%."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Recomandare: economisiți sau investiți cel puțin 10–20% din venit. În prezent: %lld%%."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Рекомендация: откладывать или инвестировать не менее 10–20 % дохода. В настоящее время: %lld%%."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekommendation: spara eller investera minst 10–20 % av inkomsten. För närvarande: %lld%%."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Öneri: Gelirin en az %10–20’sini biriktirin veya yatırın. Şu anki durum: %lld%%."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "建议：将收入的至少10–20%用于储蓄或投资。当前：%lld%%。"
          }
        }
      }
    },
