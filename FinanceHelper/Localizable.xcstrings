    "backup_footer": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تصدير جميع الحسابات والإدخالات الشهرية وبيانات الميزانية كملف JSON. يؤدي الاستيراد إلى استبدال كافة البيانات الموجودة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportuje všechny účty, měsíční položky a údaje o rozpočtu jako soubor JSON. Import nahradí všechna existující data."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksporterer alle konti, månedlige poster og budgetdata som en JSON-fil. Import erstatter alle eksisterende data."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportiert alle Konten, monatliche Einträge und Budget-Daten als JSON-Datei. Beim Import werden alle bestehenden Daten ersetzt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Exports all accounts, monthly entries, and budget data as a JSON file. Importing replaces all existing data."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta todas las cuentas, entradas mensuales y datos presupuestarios como un archivo JSON. La importación reemplaza todos los datos existentes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporte tous les comptes, entrées mensuelles et données budgétaires sous forme de fichier JSON. L'importation remplace toutes les données existantes."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Izvozi sve račune, mjesečne unose i podatke o proračunu kao JSON datoteku. Uvoz zamjenjuje sve postojeće podatke."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Exports all accounts, monthly entries, and budget data as a JSON file. Importing replaces all existing data."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Esporta tutti i conti, le voci mensili e i dati del budget come file JSON. L'importazione sostituisce tutti i dati esistenti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべてのアカウント、月次エントリ、予算データを JSON ファイルとしてエクスポートします。インポートすると、既存のデータがすべて置き換えられます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksporterer alle kontoer, månedlige oppføringer og budsjettdata som en JSON-fil. Import erstatter alle eksisterende data."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporteert alle rekeningen, maandelijkse boekingen en budgetgegevens als JSON-bestand. Bij het importeren worden alle bestaande gegevens vervangen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eksportuje wszystkie konta, wpisy miesięczne i dane budżetu jako plik JSON. Importowanie zastępuje wszystkie istniejące dane."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporta todas as contas, entradas mensais e dados de orçamento como um arquivo JSON. A importação substitui todos os dados existentes."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Exportă toate conturile, intrările lunare și datele bugetului ca fișier JSON. Importul înlocuiește toate datele existente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Экспортирует все счета, ежемесячные записи и данные бюджета в виде файла JSON. Импорт заменяет все существующие данные."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Exporterar alla konton, månadsposter och budgetdata som en JSON-fil. Import ersätter all befintlig data."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm hesapları, aylık girişleri ve bütçe verilerini bir JSON dosyası olarak dışa aktarır. İçe aktarma, mevcut tüm verilerin yerini alır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将所有帐户、每月条目和预算数据导出为 JSON 文件。导入将替换所有现有数据。"
          }
        }
      }
    },
