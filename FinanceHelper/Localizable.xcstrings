          "stringUnit": {
            "state": "translated",
            "value": "Each profile has its own accounts and entries. Swipe to delete."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cada perfil tiene sus propias cuentas y entradas. Desliza para eliminar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chaque profil a ses propres comptes et entrées. Faites glisser pour supprimer."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Svaki profil ima svoje račune i unose. Prijeđite prstom za brisanje."
