    "property_details_footer": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يساعدك سعر الشراء والتاريخ على تتبع ارتفاع قيمة عقارك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Kupní cena a datum vám pomohou sledovat zhodnocení nemovitosti."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Købspris og dato hjælper dig med at spore din ejendoms værdistigning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kaufpreis und Kaufdatum helfen dir, den Wertzuwachs deiner Immobilie zu verfolgen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Purchase price and date help you track your property's appreciation."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El precio y la fecha de compra te ayudan a seguir la revalorización de tu inmueble."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le prix et la date d'achat vous aident à suivre la valorisation de votre bien."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cijena i datum kupnje pomažu vam pratiti rast vrijednosti nekretnine."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A vételár és a dátum segít nyomon követni az ingatlan értéknövekedését."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il prezzo e la data di acquisto ti aiutano a monitorare l'apprezzamento del tuo immobile."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入価格と日付で物件の資産価値上昇を追跡できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjøpspris og dato hjelper deg med å spore verdiøkningen på eiendommen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Aankoopprijs en -datum helpen je de waardegroei van je woning bij te houden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Cena zakupu i data pomagają śledzić wzrost wartości nieruchomości."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Preço e data de compra ajudam a acompanhar a valorização do imóvel."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Prețul și data cumpărării te ajută să urmărești aprecierea proprietății."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цена покупки и дата помогут отслеживать рост стоимости недвижимости."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inköpspris och datum hjälper dig spåra fastighetens värdeökning."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Satın alma fiyatı ve tarihi, mülkünüzün değer artışını takip etmenize yardımcı olur."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "购买价格和日期有助于跟踪您房产的增值情况。"
          }
        }
      }
    },
