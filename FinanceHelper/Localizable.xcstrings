    "onboarding_feature1_desc": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "جميع الحسابات والاستثمارات والديون والنقد في لمحة — بما في ذلك صافي الثروة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Všechny účty, investice, dluhy a hotovost na jednom místě — včetně čistého jmění."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "All accounts, investments, debts, and cash at a glance — including net worth."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle Konten, Investitionen, Schulden und Bargeld auf einen Blick — inkl. Nettovermögen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All accounts, investments, debts, and cash at a glance — including net worth."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas tus cuentas, inversiones, deudas y efectivo de un vistazo — incluido el patrimonio neto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tous vos comptes, investissements, dettes et liquidités en un coup d'œil — dont la valeur nette."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Svi računi, investicije, dugovi i gotovina na jednom mjestu — uključujući neto imovinu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Minden számla, befektetés, adósság és készpénz egy pillantással – beleértve a nettó vagyont is."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutti i conti, investimenti, debiti e contanti a colpo d'occhio — incluso il patrimonio netto."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "すべての口座、投資、負債、現金を一覧で確認 — 純資産も含む。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle kontoer, investeringer, gjeld og kontanter samlet — inkl. nettoformue."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle rekeningen, investeringen, schulden en contanten in één oogopslag — inclusief nettovermogen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wszystkie konta, inwestycje, długi i gotówkę w jednym miejscu — w tym majątek netto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todas as contas, investimentos, dívidas e dinheiro em um só lugar — incluindo patrimônio líquido."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Toate conturile, investițiile, datoriile și numerarul dintr-o privire - inclusiv valoarea netă."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все счета, инвестиции, долги и наличные с первого взгляда — включая чистый капитал."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Alla konton, investeringar, skulder och kontanter i en vy — inklusive nettovärde."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tüm hesaplar, yatırımlar, borçlar ve nakit tek bakışta — net değer dahil."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有账户、投资、债务和现金一目了然 — 包括净资产。"
          }
        }
      }
    },
