    "currency_disclaimer_body": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم تخزين المبالغ بعملتها الأصلية. يعتمد العرض بالعملة الافتراضية على أسعار الصرف الحالية - بدون رسوم صرف أو فروق أسعار. هذه تقديرات."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Částky jsou uloženy v původní měně. Zobrazení ve výchozí měně je založeno na aktuálních směnných kurzech – bez směnných poplatků nebo spreadů. To jsou odhady."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Beløb opbevares i deres oprindelige valuta. Visning i standardvalutaen er baseret på aktuelle valutakurser - uden vekselgebyrer eller spreads. Det er skøn."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Beträge werden in der Originalwährung gespeichert. Die Anzeige in der Standardwährung basiert auf aktuellen Wechselkursen – ohne Wechselgebühren oder Spreads. Es handelt sich um Schätzungen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Amounts are stored in their original currency. Display in the default currency is based on current exchange rates — without exchange fees or spreads. These are estimates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los importes se almacenan en su moneda original. La visualización en la moneda predeterminada se basa en los tipos de cambio actuales, sin comisiones ni diferenciales de cambio. Estas son estimaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les montants sont stockés dans leur devise d'origine. L'affichage dans la devise par défaut est basé sur les taux de change actuels, sans frais de change ni spreads. Ce sont des estimations."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Iznosi se pohranjuju u izvornoj valuti. Prikaz u zadanoj valuti temelji se na trenutnim deviznim tečajevima — bez tečajnih naknada ili razlika. Ovo su procjene."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Amounts are stored in their original currency. Display in the default currency is based on current exchange rates — without exchange fees or spreads. These are estimates."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli importi vengono archiviati nella valuta originale. La visualizzazione nella valuta predefinita si basa sui tassi di cambio correnti, senza commissioni di cambio o spread. Queste sono stime."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "金額は元の通貨で保存されます。デフォルトの通貨での表示は、為替手数料やスプレッドなしで、現在の為替レートに基づいています。これらは推定値です。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Beløp lagres i sin opprinnelige valuta. Visning i standardvalutaen er basert på gjeldende valutakurser – uten vekslingsgebyrer eller spreads. Dette er estimater."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedragen worden opgeslagen in hun oorspronkelijke valuta. Weergave in de standaardvaluta is gebaseerd op de huidige wisselkoersen – zonder wisselkoerskosten of spreads. Dit zijn schattingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Amounts are stored in their original currency. Display in the default currency is based on current exchange rates — without exchange fees or spreads. These are estimates."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os valores são armazenados em sua moeda original. A exibição na moeda padrão é baseada nas taxas de câmbio atuais — sem taxas de câmbio ou spreads. Estas são estimativas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sumele sunt stocate în moneda lor originală. Afișarea în moneda implicită se bazează pe cursurile de schimb curente - fără taxe de schimb sau spread. Acestea sunt estimări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Суммы хранятся в исходной валюте. Отображение в валюте по умолчанию основано на текущих обменных курсах — без биржевых комиссий и спредов. Это оценки."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Beloppen lagras i sin ursprungliga valuta. Visning i standardvalutan baseras på aktuella växelkurser — utan växlingsavgifter eller spreadar. Detta är uppskattningar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tutarlar orijinal para birimlerinde saklanır. Varsayılan para birimindeki gösterim, döviz ücretleri veya spreadler olmaksızın mevcut döviz kurlarına dayanmaktadır. Bunlar tahminlerdir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "金额以其原始货币存储。以默认货币显示是基于当前汇率 - 没有兑换费或点差。这些是估计值。"
          }
        }
      }
    },
