    "delete_transfer_message": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الإدخال هو جزء من النقل. هل يجب أيضًا حذف الإدخال المطابق في الحساب الآخر؟"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Tento záznam je součástí převodu. Má být smazán také odpovídající záznam na druhém účtu?"
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne post er en del af en overførsel. Skal den matchende post på den anden konto også slettes?"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieser Eintrag ist Teil einer Überweisung. Soll auch der Gegen-Eintrag auf dem anderen Konto gelöscht werden?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This entry is part of a transfer. Should the matching entry on the other account also be deleted?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta entrada es parte de una transferencia. ¿Debería eliminarse también la entrada coincidente de la otra cuenta?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette entrée fait partie d'un transfert. L'entrée correspondante sur l'autre compte doit-elle également être supprimée ?"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ovaj unos je dio prijenosa. Treba li i odgovarajući unos na drugom računu također biti izbrisan?"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ez a bejegyzés egy átutalás része. A másik fiók egyező bejegyzését is törölni kell?"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questa voce fa parte di un trasferimento. È opportuno eliminare anche la registrazione corrispondente sull'altro conto?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This entry is part of a transfer. Should the matching entry on the other account also be deleted?"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Denne oppføringen er en del av en overføring. Bør den samsvarende oppføringen på den andre kontoen også slettes?"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze boeking maakt deel uit van een overdracht. Moet de overeenkomende vermelding op het andere account ook worden verwijderd?"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "This entry is part of a transfer. Should the matching entry on the other account also be deleted?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Esta entrada faz parte de uma transferência. A entrada correspondente na outra conta também deve ser excluída?"
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Această intrare face parte dintr-un transfer. Ar trebui ștearsă și intrarea potrivită din celălalt cont?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Эта запись является частью перевода. Следует ли также удалить соответствующую запись в другой учетной записи?"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Denna post är en del av en överföring. Ska den matchande posten på det andra kontot också raderas?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu giriş bir transferin parçasıdır. Diğer hesaptaki eşleşen girişin de silinmesi gerekir mi?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此条目是传输的一部分。其他帐户上的匹配条目是否也应删除？"
          }
        }
      }
    },
