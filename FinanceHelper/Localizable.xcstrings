          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Cheltuieli lunare cu cardul de credit raportate la venituri. Ținta: sub 30%."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
