          "stringUnit": {
            "state": "translated",
            "value": "Ostavite prazno = primijeni na sve račune."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Üresen hagyni = minden fiókra alkalmazni."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Lasciare vuoto = applicare a tutti i conti."
          }
        },
