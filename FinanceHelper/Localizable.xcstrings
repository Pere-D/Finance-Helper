    "inactive_entry_hint": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تظل الإدخالات المعطلة محفوظة ولكن يتم استبعادها من جميع الحسابات."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivované položky zůstávají uloženy, ale jsou vyloučeny ze všech výpočtů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deactivated entries remain saved but are excluded from all calculations."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktivierte Einträge bleiben gespeichert, werden aber aus allen Berechnungen ausgeschlossen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deactivated entries remain saved but are excluded from all calculations."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las entradas desactivadas permanecen guardadas pero se excluyen de todos los cálculos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées désactivées restent enregistrées mais sont exclues de tous les calculs."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deactivated entries remain saved but are excluded from all calculations."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A deaktivált bejegyzések mentésre kerülnek, de kizárják őket a számításokból."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le voci disattivate rimangono salvate ma sono escluse da tutti i calcoli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "非アクティブ化されたエントリは保存されたままですが、すべての計算から除外されます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Deaktiverte oppføringer forblir lagret, men ekskluderes fra alle beregninger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gedeactiveerde gegevens blijven opgeslagen, maar worden bij alle berekeningen uitgesloten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Deactivated entries remain saved but are excluded from all calculations."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As entradas desativadas permanecem salvas, mas são excluídas de todos os cálculos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Intrările dezactivate rămân salvate, dar sunt excluse din toate calculele."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Деактивированные записи остаются сохраненными, но исключаются из всех расчетов."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktiverade poster förblir sparade men exkluderas från alla beräkningar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Devre dışı bırakılan girişler kayıtlı kalır ancak tüm hesaplamaların dışında bırakılır."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停用的条目仍然保存，但从所有计算中排除。"
          }
        }
      }
    },
