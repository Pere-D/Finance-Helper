    "Automatisch generiert — wird nach dem Speichern als eigene Regel markiert.": {
      "comment": "A footnote explaining that an automatically generated rule will be marked as such after it is saved.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تم إنشاؤها تلقائيًا — يتم وضع علامة عليها كقاعدة مستقلة بعد الحفظ."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Automaticky vygenerováno — po uložení se označí jako samostatné pravidlo."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Genereres automatisk — markeres som en separat regel efter gemning."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatisch generiert — wird nach dem Speichern als eigene Regel markiert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatically generated — will be marked as a separate rule after saving."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Generado automáticamente: tras guardarlo, se marca como una regla independiente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Généré automatiquement — sera marqué comme règle distincte après l'enregistrement."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatski generirano — nakon spremanja bit će označeno kao zasebno pravilo."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatikusan generált — a mentés után külön szabályként kerül megjelölésre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Generato automaticamente — dopo il salvataggio viene contrassegnato come regola separata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動生成 — 保存後に独自のルールとしてマークされます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Genereres automatisk — merkes som en egen regel etter at den er lagret."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Automatisch gegenereerd — wordt na het opslaan gemarkeerd als een afzonderlijke regel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wygenerowane automatycznie — po zapisaniu zostanie oznaczone jako osobna reguła."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Gerado automaticamente — será marcado como uma regra separada após o salvamento."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Generat automat — după salvare, este marcat ca regulă separată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создано автоматически — после сохранения помечается как отдельное правило."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
