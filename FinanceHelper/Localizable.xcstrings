    "Erscheinen als einmaliger Betrag im jeweiligen Monat der Prognose.": {
      "comment": "A footer text explaining how bonus payments are treated in the budget forecast.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يظهر كمبلغ واحد في الشهر المعني من التوقعات."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V daném měsíci prognózy se objeví jako jednorázová částka."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fremgår som et engangsbeløb i den pågældende måned i prognosen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erscheinen als einmaliger Betrag im jeweiligen Monat der Prognose."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Appears as a one-time amount in the respective month of the forecast."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aparece como un importe único en el mes correspondiente de la previsión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apparaît sous la forme d'un montant unique au cours du mois concerné par les prévisions."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pojavljuje se kao jednokratni iznos u odgovarajućem mjesecu prognoze."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az előrejelzésben szereplő adott hónapban egyszeri összegként jelenik meg."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Viene indicato come importo una tantum nel mese di riferimento della previsione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予測対象の各月に一括額として計上される。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Vises som et engangsbeløp i den aktuelle måneden i prognosen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wordt weergegeven als een eenmalig bedrag in de betreffende maand van de prognose."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Występuje jako kwota jednorazowa w danym miesiącu prognozy."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aparece como um valor único no mês correspondente da previsão."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Se înregistrează ca sumă unică în luna respectivă a prognozei."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отображается в виде единовременной суммы в соответствующем месяце прогноза."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Redovisas som ett engångsbelopp under den aktuella månaden i prognosen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tahmin edilen ilgili ayda tek seferlik bir tutar olarak gösterilir."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在预测的相应月份中以一次性金额的形式列示。"
          }
        }
      }
    },
