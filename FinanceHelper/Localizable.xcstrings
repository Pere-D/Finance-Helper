    "monthly_repayment_from_entries_hint": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتم احتساب الدفعة الشهرية تلقائيًا من إدخالات الميزانية المرتبطة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Měsíční splátka se automaticky vypočítá z propojených rozpočtových položek."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Den månedlige betaling beregnes automatisk ud fra de tilknyttede budgetposter."
