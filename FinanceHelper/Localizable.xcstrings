    "criterion_credit_desc": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مصاريف بطاقة الائتمان الشهرية مقارنة بالدخل. الهدف: أقل من 30%."
          }
        },
        "cs": {
          "stringUnit": {
