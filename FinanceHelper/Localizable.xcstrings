    "onboarding_accounts_subtitle": {
      "extractionState": "stale",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف حساباتك الأكثر أهمية — حتى تكون لوحة التحكم مليئة منذ البداية. يمكنك الإضافة في أي وقت."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přidejte své nejdůležitější účty — aby byl váš přehled vyplněn od začátku. Další můžete přidávat kdykoli."
          }
        },
        "da": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Add your most important accounts — so your dashboard is filled from the start. You can add more anytime."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge deine wichtigsten Konten hinzu — damit dein Dashboard von Anfang an gefüllt ist. Du kannst jederzeit weitere ergänzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add your most important accounts — so your dashboard is filled from the start. You can add more anytime."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agrega tus cuentas más importantes — para que tu panel esté lleno desde el principio. Puedes agregar más en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez vos comptes les plus importants — pour que votre tableau de bord soit rempli dès le début. Vous pouvez en ajouter à tout moment."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodajte svoje najvažnije račune — kako bi vaša nadzorna ploča bila popunjena od samog početka. Uvijek možete dodati više."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Adja hozzá legfontosabb fiókjait – így az irányítópult kezdettől fogva tele lesz. Bármikor hozzáadhat továbbiakat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi i tuoi conti più importanti — così il tuo pannello sarà pieno fin dall'inizio. Puoi aggiungerne altri in qualsiasi momento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "主要な口座を追加して、ダッシュボードを最初から充実させましょう。いつでも追加できます。"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Legg til de viktigste kontoene dine — slik at dashbordet ditt er fylt fra starten. Du kan legge til flere når som helst."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg je belangrijkste rekeningen toe — zodat je dashboard vanaf het begin gevuld is. Je kunt altijd meer toevoegen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj swoje najważniejsze konta — aby Twój panel był wypełniony od samego początku. Możesz dodawać więcej w dowolnym momencie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione suas contas mais importantes — para que seu painel esteja preenchido desde o início. Você pode adicionar mais a qualquer momento."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Adăugați cele mai importante conturi ale dvs. - astfel încât tabloul de bord să fie umplut de la început. Puteți adăuga mai multe oricând."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте свои основные счета — чтобы ваша панель была заполнена с самого начала. Вы можете добавить ещё в любое время."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till dina viktigaste konton — så att din instrumentpanel är fylld från början. Du kan lägga till fler när som helst."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "En önemli hesaplarınızı ekleyin — böylece paneliniz baştan dolu olur. İstediğiniz zaman daha fazla ekleyebilirsiniz."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加您最重要的账户 — 让仪表盘从一开始就充实起来。随时可以添加更多。"
          }
        }
      }
    },
